rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anyone to read users (needed for ID duplicate check and login email mapping)
    // Allow users to create their own profile during signup
    // Allow users to update their own profile, or master to update any
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || resource.data.role == 'master');
      allow delete: if request.auth != null && (request.auth.uid == userId || resource.data.role == 'master');
    }
  }
}
