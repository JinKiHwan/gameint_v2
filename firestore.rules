rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isMaster() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'master';
    }
    function isActiveUser() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active';
    }

    match /users/{userId} {
      // Allow anyone to read users (needed for ID duplicate check)
      allow read: if true;
      
      // Allow users to create their own profile during signup, forcing default role/status
      allow create: if isAuthenticated() && request.auth.uid == userId
                    && request.resource.data.role == 'user'
                    && request.resource.data.status == 'pending';
                    
      // Allow users to update their own profile (but prevent tampering with status/role)
      // OR allow master to update any field
      allow update: if (isAuthenticated() && request.auth.uid == userId 
                        && request.resource.data.role == resource.data.role 
                        && request.resource.data.status == resource.data.status)
                    || isMaster();
                    
      // Only masters can delete users
      allow delete: if isMaster();
    }
    
    // Posts collection permissions
    match /posts/{postId} {
      // Anyone logged in and active can read posts
      allow read: if isActiveUser();
      
      // Active users can create new posts (preventing spoofing of uid)
      allow create: if isActiveUser() && request.resource.data.author.uid == request.auth.uid;
      
      // Post authors (or masters) can update or delete
      // Notice: viewCount and commentCount increases bypass the author.uid check so any active user can update them
      allow update: if isActiveUser() && (
                      resource.data.author.uid == request.auth.uid || 
                      isMaster() ||
                      // Exception for viewCount and commentCount increments
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount', 'commentCount']))
                    );
                    
      allow delete: if isActiveUser() && (resource.data.author.uid == request.auth.uid || isMaster());

      // Comments sub-collection permissions
      match /comments/{commentId} {
        allow read: if isActiveUser();
        allow create: if isActiveUser() && request.resource.data.author.uid == request.auth.uid;
        allow update, delete: if isActiveUser() && (resource.data.author.uid == request.auth.uid || isMaster());
      }
    }

    match /{document=**} {
      allow read, write: if false; 
    }
  }
}
