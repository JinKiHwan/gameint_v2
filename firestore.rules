rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isMaster() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'master';
    }
    function isActiveUser() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active';
    }

    match /users/{userId} {
      // Allow anyone to read users (needed for ID duplicate check)
      allow read: if true;
      
      // Allow users to create their own profile during signup, forcing default role/status
      allow create: if isAuthenticated() && request.auth.uid == userId
                    && request.resource.data.role == 'user'
                    && request.resource.data.status == 'pending';
                    
      // Allow users to update their own profile (but prevent tampering with status/role)
      // OR allow master to update any field
      allow update: if (isAuthenticated() && request.auth.uid == userId 
                        && request.resource.data.role == resource.data.role 
                        && request.resource.data.status == resource.data.status)
                    || isMaster();
                    
      // Only masters can delete users
      allow delete: if isMaster();

      // Notifications sub-collection
      match /notifications/{notiId} {
        allow read, update, delete: if isAuthenticated() && request.auth.uid == userId;
      }
    }
    
    // Posts collection permissions
    match /posts/{postId} {
      // Anyone logged in and active can read posts
      allow read: if isActiveUser();
      
      // Active users can create new posts
      allow create: if isActiveUser() && request.resource.data.author.uid == request.auth.uid;
      
      // Notice: viewCount, commentCount, and likeCount increases bypass the author.uid check
      allow update: if isActiveUser() && (
                      resource.data.author.uid == request.auth.uid || 
                      isMaster() ||
                      // Exception for viewCount, commentCount, and likeCount increments
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount', 'commentCount', 'likeCount']))
                    );
                    
      allow delete: if isActiveUser() && (resource.data.author.uid == request.auth.uid || isMaster());

      // Comments sub-collection permissions
      match /comments/{commentId} {
        allow read: if isActiveUser();
        allow create: if isActiveUser() && request.resource.data.author.uid == request.auth.uid;
        allow update, delete: if isActiveUser() && (resource.data.author.uid == request.auth.uid || isMaster());
      }
      
      // Likes sub-collection permissions (Used for optimistic deduplication)
      match /likes/{userId} {
        allow read: if isActiveUser();
        allow write: if isActiveUser() && request.auth.uid == userId;
      }
    }

    // Cycles collection permissions
    match /cycles/{cycleId} {
      allow read: if isActiveUser();
      allow create, update, delete: if isMaster();

      // participants sub-collection
      match /participants/{uid} {
        allow read: if isActiveUser();
        // active user can write their own participation doc
        allow create, update: if isActiveUser() && request.auth.uid == uid;
        // master can update voteCount etc.
        allow update: if isMaster();
        allow delete: if isMaster();
      }

      // votes sub-collection (1 vote per user)
      match /votes/{uid} {
        allow read: if isActiveUser();
        allow create, update: if isActiveUser() && request.auth.uid == uid;
        allow delete: if isMaster();
      }

      // reviews sub-collection
      match /reviews/{reviewId} {
        allow read: if isActiveUser();
        allow create: if isActiveUser() && request.resource.data.authorUid == request.auth.uid;
        allow update, delete: if isActiveUser() && resource.data.authorUid == request.auth.uid || isMaster();
      }

      // meetings sub-collection (master only writes, all active users read)
      match /meetings/{meetingId} {
        allow read: if isActiveUser();
        allow create, update, delete: if isMaster();
      }
    }

    // Global Notifications collection
    match /global_notifications/{notiId} {
      allow read: if isActiveUser();
      allow write: if isMaster(); // Only system/master should write (mostly via Functions)
    }

    // Collection Group rules for reviews
    match /{path=**}/reviews/{reviewId} {
      allow read: if isActiveUser();
    }

    match /{document=**} {
      allow read, write: if false; 
    }
  }
}
